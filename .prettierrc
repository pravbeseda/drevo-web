{
    "singleQuote": true,
    "singleAttributePerLine": true,
    "arrowParens": "avoid",
    "tabWidth": 4,
    "htmlWhitespaceSensitivity": "ignore",
    "useTabs": false,
    "semi": true,
    "bracketSpacing": true,
    "trailingComma": "all",
    "bracketSameLine": false,
    "printWidth": 120
}
