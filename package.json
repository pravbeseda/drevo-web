{
    "name": "@drevo-web/source",
    "version": "0.0.0",
    "license": "MIT",
    "scripts": {
        "test": "nx run-many --target=test --all --parallel",
        "test:coverage": "nx run-many --target=test --all --parallel --coverage",
        "lint": "yarn nx affected -t lint --parallel",
        "format:check": "node ./node_modules/.bin/prettier . --check",
        "format:fix": "node ./node_modules/.bin/prettier . --write",
        "e2e": "yarn playwright test --config=apps/client-e2e/playwright.config.ts",
        "e2e:api": "yarn playwright test --project=api --config=apps/client-e2e/playwright.config.ts",
        "generate-version": "node scripts/generate-version.js",
        "build": "nx build client --configuration=production",
        "build:dev": "nx build client --configuration=development",
        "start": "node dist/apps/client/server/server.mjs",
        "serve": "nx serve client",
        "test:playwright": "playwright test --config=testing/playwright/playwright.config.ts --project=chromium",
        "test:playwright:coverage": "COVERAGE=true playwright test --config=testing/playwright/playwright.config.ts --project=chromium",
        "test:playwright:firefox": "playwright test --config=testing/playwright/playwright.config.ts --project=firefox",
        "test:playwright:webkit": "playwright test --config=testing/playwright/playwright.config.ts --project=webkit",
        "test:playwright:mobile": "playwright test --config=testing/playwright/playwright.config.ts --project=mobile-chrome --project=mobile-safari",
        "test:playwright:all": "playwright test --config=testing/playwright/playwright.config.ts",
        "test:playwright:ui": "playwright test --config=testing/playwright/playwright.config.ts --ui",
        "test:playwright:headed": "playwright test --config=testing/playwright/playwright.config.ts --headed"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "21.2.6",
        "@angular/cdk": "21.2.4",
        "@angular/cdk-experimental": "21.2.4",
        "@angular/common": "21.2.6",
        "@angular/compiler": "21.2.6",
        "@angular/core": "21.2.7",
        "@angular/forms": "21.2.6",
        "@angular/material": "21.2.4",
        "@angular/platform-browser": "21.2.6",
        "@angular/platform-browser-dynamic": "21.2.6",
        "@angular/platform-server": "21.2.6",
        "@angular/router": "21.2.6",
        "@angular/ssr": "21.2.5",
        "@codemirror/autocomplete": "^6.20.0",
        "@codemirror/commands": "^6.10.1",
        "@codemirror/language": "^6.12.1",
        "@codemirror/merge": "^6.11.2",
        "@codemirror/state": "^6.5.4",
        "@codemirror/view": "^6.39.12",
        "@sentry/angular": "^10.34.0",
        "axios": "^1.15.0",
        "codemirror": "^6.0.2",
        "dexie": "^4.2.1",
        "diff": "^8.0.3",
        "diff-match-patch": "^1.0.5",
        "express": "^4.21.2",
        "modern-normalize": "^3.0.1",
        "rxjs": "~7.8.0"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "21.2.5",
        "@angular-devkit/core": "21.2.5",
        "@angular-devkit/schematics": "21.2.5",
        "@angular/cli": "21.2.5",
        "@angular/compiler-cli": "21.2.6",
        "@angular/language-service": "21.2.6",
        "@eslint/js": "^9.8.0",
        "@ngneat/spectator": "^22.1.0",
        "@nx/angular": "22.6.3",
        "@nx/devkit": "22.6.3",
        "@nx/eslint": "22.6.3",
        "@nx/eslint-plugin": "22.6.3",
        "@nx/jest": "22.6.3",
        "@nx/js": "22.6.3",
        "@nx/playwright": "22.6.3",
        "@nx/web": "22.6.3",
        "@nx/workspace": "22.6.3",
        "@playwright/test": "^1.36.0",
        "@schematics/angular": "21.2.5",
        "@sentry/cli": "^3.1.0",
        "@swc-node/register": "1.11.1",
        "@swc/core": "1.15.8",
        "@swc/helpers": "0.5.19",
        "@swc/types": "0.1.17",
        "@types/diff-match-patch": "^1.0.36",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/node": "18.16.9",
        "@typescript-eslint/utils": "^8.40.0",
        "angular-eslint": "21.3.1",
        "eslint": "^9.28.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-no-null": "^1.0.2",
        "eslint-plugin-playwright": "^1.6.2",
        "jest": "^30.0.0",
        "jest-environment-jsdom": "^30.0.0",
        "jest-environment-node": "^30.0.0",
        "jest-preset-angular": "^16.0.0",
        "jest-util": "^30.0.0",
        "jsonc-eslint-parser": "^2.1.0",
        "monocart-coverage-reports": "^2.12.9",
        "monocart-reporter": "^2.10.0",
        "ng-mocks": "^14.15.0",
        "nx": "22.6.3",
        "prettier": "3.8.1",
        "serve": "^14.2.6",
        "ts-jest": "29.4.6",
        "ts-node": "10.9.1",
        "tslib": "^2.3.0",
        "typescript": "5.9.3",
        "typescript-eslint": "^8.33.1",
        "wait-on": "^9.0.4",
        "zone.js": "0.16.0"
    }
}
